{
  "name": "generate-build-manifest",
  "version": "4.0.0",
  "description": "GitHub Action to generate manifest files for NodeJS projects",
  "main": "dist/index.js",
  "scripts": {
    "biome": "biome check .",
    "biome:fix": "biome check . --write",
    "biome:fix-unsafe": "biome check . --write --unsafe",
    "prepare": "husky",
    "ghadocs": "github-action-readme-generator --readme README.md && git add README.md",
    "pack": "tsdown src/index.ts --format cjs --out-dir dist --no-splitting --minify",
    "pack:sourcemap": "tsdown src/index.ts --format cjs --out-dir dist --no-splitting --sourcemap"
  },
  "author": "Fernando A. Maule <fer@maule.pro>",
  "license": "ISC",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@octokit/webhooks-definitions": "^3.68.1",
    "@types/node": "^22.0.0",
    "github-action-readme-generator": "^1.10.7",
    "husky": "^9.1.7",
    "tsdown": "^0.12.9",
    "typescript": "^5.9.3"
  }
}
